# Voice AI RAG — Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayıp GEMINI_API_KEY'i doldurun.
# cp .env.example .env

# ============================================================
# ZORUNLU
# ============================================================

# Google Gemini API anahtarı (ücretsiz kota mevcut)
# Alın: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================
# UYGULAMA
# ============================================================

APP_NAME=Voice AI RAG
APP_VERSION=1.0.0
DEBUG=false

# ============================================================
# LLM — Google Gemini
# ============================================================

# Kullanılabilir modeller:
#   gemini-2.0-flash       (hızlı, varsayılan)
#   gemini-1.5-flash       (dengeli)
#   gemini-1.5-pro         (en yetenekli, daha yavaş)
GEMINI_MODEL=gemini-2.0-flash

# ============================================================
# STT — Faster Whisper (lokal, API gerekmez)
# ============================================================

# Model boyutu: tiny | base | small | medium | large-v3
# Öneri: small (273 MB, Türkçe için iyi denge)
WHISPER_MODEL_SIZE=small

# Cihaz: cpu | cuda (NVIDIA GPU varsa cuda kullanın)
WHISPER_DEVICE=cpu

# Hesaplama tipi:
#   int8    → CPU için (bellek tasarruflu)
#   float16 → GPU (cuda) için
#   float32 → Maksimum doğruluk
WHISPER_COMPUTE_TYPE=int8

# Transkripsiyon dili (ISO 639-1)
SPEECH_LANGUAGE=tr

# ============================================================
# TTS — Piper (lokal, API gerekmez)
# ============================================================

# Türkçe model dosyasını indirin ve backend/models/ altına koyun:
#   tr_TR-dfki-medium.onnx
#   tr_TR-dfki-medium.onnx.json
#
# İndirme komutu (Linux/Mac):
#   wget https://huggingface.co/rhasspy/piper-voices/resolve/main/tr/tr_TR/dfki/medium/tr_TR-dfki-medium.onnx
#   wget https://huggingface.co/rhasspy/piper-voices/resolve/main/tr/tr_TR/dfki/medium/tr_TR-dfki-medium.onnx.json
PIPER_MODEL_PATH=models/tr_TR-dfki-medium.onnx

# ============================================================
# RAG — Embedding & ChromaDB
# ============================================================

# Çok dilli embedding modeli (Türkçe dahil 50+ dil)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Belge parçalama ayarları
CHUNK_SIZE=500          # Her parçanın maksimum karakter sayısı
CHUNK_OVERLAP=50        # Parçalar arası örtüşme miktarı

# Sorgu başına kaç chunk getirilsin (1-20)
RETRIEVAL_TOP_K=5

# ============================================================
# DEPOLAMA
# ============================================================

DOCUMENTS_PATH=data/documents    # Yüklenen dosyaların dizini
CHROMA_PATH=data/chroma_db       # ChromaDB kalıcı depolama

# ============================================================
# CORS
# ============================================================

# Üretimde güvenlik için spesifik origin'ler belirtin:
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
CORS_ORIGINS=*
